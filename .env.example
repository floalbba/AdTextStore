# NeonDB (PostgreSQL) — скопируй в .env и подставь свои значения
# Получить строки подключения: https://console.neon.tech

# Pooled connection (для приложения)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require"

# Direct connection (для миграций Prisma)
# connect_timeout=30 даёт Neon время «проснуться» при Scale to Zero
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require&connect_timeout=30"

# Локальная БД (для view-db, если отличается от production)
# DATABASE_URL_LOCAL="postgresql://..."
